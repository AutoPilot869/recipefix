{
  "manifest_version": 3,
  "name": "RecipeFix",
  "version": "4.0.0",
  "description": "Inline ingredient badges for recipe directions. Tap to mark done.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": ["<all_urls>"]
}
